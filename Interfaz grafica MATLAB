function mostrarImagen(ax, img)
    cla(ax);
    if ismatrix(img)
        img = repmat(img, 1, 1, 3);
    end
    image(ax, img);
    ax.XTick = []; ax.YTick = [];
    ax.XColor = 'none'; ax.YColor = 'none';
    ax.DataAspectRatio = [1 1 1];
    ax.PlotBoxAspectRatioMode = 'auto';
    ax.Color = [0.08 0.10 0.13];
    axis(ax, 'tight');
end

function edge_img = edge_kirsch(img)
    img = double(img);
    K{1} = [-3 -3  5; -3  0  5; -3 -3  5];
    K{2} = [-3  5  5; -3  0  5; -3 -3 -3];
    K{3} = [ 5  5  5; -3  0 -3; -3 -3 -3];
    K{4} = [ 5  5 -3;  5  0 -3; -3 -3 -3];
    K{5} = [ 5 -3 -3;  5  0 -3;  5 -3 -3];
    K{6} = [-3 -3 -3;  5  0 -3;  5  5 -3];
    K{7} = [-3 -3 -3; -3  0 -3;  5  5  5];
    K{8} = [-3 -3 -3; -3  0  5; -3  5  5];
    [fil, col] = size(img);
    edge_img = zeros(fil, col);
    for i = 2:fil-1
        for j = 2:col-1
            ventana = img(i-1:i+1, j-1:j+1);
            max_val = 0;
            for k = 1:8
                valor = abs(sum(sum(ventana .* K{k})));
                if valor > max_val, max_val = valor; end
            end
            edge_img(i, j) = max_val;
        end
    end
    edge_img = uint8(edge_img);
end

function bw = threshold_custom(img, umbral)
    if isa(img, 'uint8'), img = double(img); end
    bw = uint8(img >= umbral) * 255;
end
