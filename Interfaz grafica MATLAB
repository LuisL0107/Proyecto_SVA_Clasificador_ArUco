%% ===== FUNCIONES LOCALES =====

    function sincronizarCampo(val)
        txtPuertoManual.Value = val;
    end

    function escribirLog(msg)
        actual = txtLog.Value;
        if ischar(actual), actual = {actual}; end
        nueva = [actual; {['> ' msg]}];
        if length(nueva) > 50, nueva = nueva(end-49:end); end
        txtLog.Value = nueva;
        scroll(txtLog, 'bottom');
    end

    function escribirSerial(msg, direccion)
        ts = datestr(now, 'HH:MM:SS');
        if strcmp(direccion, 'TX')
            linea = ['[' ts '] TX >> ' msg];
            color = [0.4 0.85 0.55];
        else
            linea = ['[' ts '] RX << ' msg];
            color = [0.4 0.75 0.95];
        end
        actual = txtSerial.Value;
        if ischar(actual), actual = {actual}; end
        nueva = [actual; {linea}];
        if length(nueva) > 100, nueva = nueva(end-99:end); end
        txtSerial.Value = nueva;
        txtSerial.FontColor = color;
        scroll(txtSerial, 'bottom');
    end

    function leerSerial()
        if ~estado.conectado || isempty(estado.P), return; end
        try
            nbytes = estado.P.NumBytesAvailable;
            if nbytes > 0
                datos = read(estado.P, nbytes, 'char');
                lineas = strsplit(strtrim(datos), {char(10), char(13)});
                for k = 1:length(lineas)
                    if ~isempty(strtrim(lineas{k}))
                        escribirSerial(strtrim(lineas{k}), 'RX');
                    end
                end
            end
        catch
        end
    end

    function limpiarMonitor()
        txtSerial.Value = {'[Monitor limpiado]'};
    end

    function refrescarPuertos()
        nuevosPuertos = obtenerPuertos();
        ddPuerto.Items = nuevosPuertos;
        if ~isempty(nuevosPuertos)
            txtPuertoManual.Value = nuevosPuertos{1};
            ddPuerto.Value = nuevosPuertos{1};
        end
        escribirLog(['Puertos refrescados: ' strjoin(nuevosPuertos, ', ')]);
    end

    function conectarPuerto()
        try
            if estado.conectado
                clear estado.P;
                estado.P = [];
                estado.conectado = false;
                lblEstadoPuerto.Text = '● Desconectado';
                lblEstadoPuerto.FontColor = [0.85 0.3 0.3];
                btnConectar.Text = '⚡ Conectar Puerto';
                btnConectar.BackgroundColor = [0.2 0.55 0.35];
                escribirLog('Puerto serial cerrado.');
            else
                puerto = strtrim(txtPuertoManual.Value);
                if isempty(puerto), puerto = ddPuerto.Value; end
                baud = str2double(ddBaud.Value);
                estado.P = serialport(puerto, baud);
                estado.conectado = true;
                lblEstadoPuerto.Text = ['● Conectado: ' puerto];
                lblEstadoPuerto.FontColor = [0.3 0.85 0.5];
                btnConectar.Text = '✕ Desconectar';
                btnConectar.BackgroundColor = [0.6 0.2 0.22];
                escribirLog(['Puerto ' puerto ' @ ' num2str(baud) ' baud conectado.']);
            end
        catch ME
            escribirLog(['ERROR puerto: ' ME.message]);
            uialert(fig, ME.message, 'Error de Puerto', 'Icon', 'error');
        end
    end

    function abrirCamara()
        try
            if estado.camaraActiva
                clear estado.cam;
                estado.cam = [];
                estado.camaraActiva = false;
                lblEstadoCam.Text = '● Cámara cerrada';
                lblEstadoCam.FontColor = [0.85 0.3 0.3];
                btnAbrirCam.Text = '📷 Abrir Cámara';
                btnAbrirCam.BackgroundColor = [0.22 0.45 0.72];
                ddResolucion.Items = {'(abre la cámara)'};
                ddResolucion.Enable = 'off';
                ddResolucion.FontColor = [0.55 0.6 0.65];
                btnAplicarRes.Enable = 'off';
                escribirLog('Cámara liberada.');
            else
                idxCam = spnCamara.Value;
                estado.cam = webcam(idxCam);
                res = estado.cam.AvailableResolutions;
                ddResolucion.Items = res;
                ddResolucion.Enable = 'on';
                ddResolucion.FontColor = [0.9 0.92 0.95];
                btnAplicarRes.Enable = 'on';
                if any(strcmp(res, '1280x960'))
                    estado.cam.Resolution = '1280x960';
                    ddResolucion.Value = '1280x960';
                else
                    estado.cam.Resolution = res{end};
                    ddResolucion.Value = res{end};
                end
                escribirLog(['Cámara ' num2str(idxCam) ': ' num2str(length(res)) ' resoluciones disponibles:']);
                for r = 1:length(res)
                    if strcmp(res{r}, estado.cam.Resolution)
                        escribirLog(['  [' num2str(r) '] ' res{r} '  ← activa']);
                    else
                        escribirLog(['  [' num2str(r) '] ' res{r}]);
                    end
                end
                estado.camaraActiva = true;
                lblEstadoCam.Text = ['● Cámara ' num2str(idxCam) ': ' estado.cam.Resolution];
                lblEstadoCam.FontColor = [0.3 0.85 0.5];
                btnAbrirCam.Text = '■ Cerrar Cámara';
                btnAbrirCam.BackgroundColor = [0.55 0.2 0.22];
                escribirLog(['Usando: ' estado.cam.Resolution]);
            end
        catch ME
            escribirLog(['ERROR cámara: ' ME.message]);
            uialert(fig, ME.message, 'Error de Cámara', 'Icon', 'error');
        end
    end

    function usarImagenCompleta()
        if ~estado.camaraActiva
            uialert(fig, 'Abre la cámara primero.', 'Cámara no activa', 'Icon', 'warning');
            return;
        end
        resActiva = estado.cam.Resolution;
        partes = strsplit(resActiva, 'x');
        spnX.Value     = 0;
        spnY.Value     = 0;
        spnAncho.Value = str2double(partes{1});
        spnAlto.Value  = str2double(partes{2});
        escribirLog(['Recorte → imagen completa (' resActiva ')']);
    end

    function aplicarResolucion()
        if ~estado.camaraActiva, return; end
        try
            resElegida = ddResolucion.Value;
            estado.cam.Resolution = resElegida;
            lblEstadoCam.Text = ['● Cámara activa: ' resElegida];
            escribirLog(['Resolución cambiada a: ' resElegida]);
        catch ME
            escribirLog(['ERROR al cambiar resolución: ' ME.message]);
        end
    end

    % ---- Dibuja histograma en el axes indicado ----
    function dibujarHistograma(ax, img, color)
        cla(ax);
        % Convertir a escala de grises si es RGB
        if ndims(img) == 3
            imgG = rgb2gray(img);
        else
            imgG = img;
        end
        imgG = double(imgG(:));

        % Calcular histograma con imhist (256 bins, Image Processing Toolbox)
        [cuenta, xout] = imhist(uint8(imgG), 64);

        % Dibujar como área rellena
        area(ax, xout, cuenta, ...
            'FaceColor', color, ...
            'EdgeColor', color * 0.7, ...
            'FaceAlpha', 0.75, ...
            'LineWidth', 0.5);

        ax.Color     = [0.08 0.10 0.14];
        ax.XColor    = [0.45 0.5 0.55];
        ax.YColor    = [0.45 0.5 0.55];
        ax.FontSize  = 7;
        ax.XLim      = [0 255];
        ax.Box       = 'off';
        ax.YGrid     = 'on';
        ax.GridColor = [0.25 0.28 0.35];
        ax.GridAlpha = 0.4;
        ax.XLabel.String = 'Intensidad';
        ax.XLabel.FontSize = 7;
        ax.XLabel.Color = [0.45 0.5 0.55];
        ax.YLabel.String = 'N';
        ax.YLabel.FontSize = 7;
        ax.YLabel.Color = [0.45 0.5 0.55];
    end

    function capturarYAnalizar()
        if ~estado.camaraActiva
            uialert(fig, 'Abre la cámara primero.', 'Cámara no activa', 'Icon', 'warning');
            return;
        end

        btnCapturar.Enable = 'off';
        btnCapturar.Text = '⏳ Procesando...';
        btnCapturar.BackgroundColor = [0.45 0.65 0.5];
        drawnow;

        try
            %--- 1. CAPTURA ---
            escribirLog('Capturando frame...');
            pause(0.5);
            frame = snapshot(estado.cam);
            estado.frame1 = frame;
            mostrarImagen(axImg(1), frame);
            dibujarHistograma(axHist(1), frame, coloresHist{1});
            drawnow;

            %--- 2. RECORTE ---
            GS = rgb2gray(frame);
            x = spnX.Value;  y = spnY.Value;
            w = spnAncho.Value;  h = spnAlto.Value;
            [fh, fw] = size(GS);
            x = min(x, fw-10); y = min(y, fh-10);
            w = min(w, fw-x);  h = min(h, fh-y);

            imgRec      = imcrop(GS, [x y w h]);
            imgRecColor = imcrop(frame, [x y w h]);
            estado.imgRecortada = imgRec;

            mostrarImagen(axImg(2), imgRec);
            dibujarHistograma(axHist(2), imgRec, coloresHist{2});
            drawnow;
            escribirLog(['Recorte: x=' num2str(x) ' y=' num2str(y) ...
                         ' ' num2str(w) 'x' num2str(h)]);

            %--- 3. DETECCIÓN ArUco ---
            markerFamily  = 'DICT_4x4_250';
            imgMarcadores = imgRecColor;

            try
                [ids, locations, ~] = readArucoMarker(imgRec, markerFamily);

                if ~isempty(ids)
                    escribirLog([num2str(length(ids)) ' marcador(es) detectado(s).']);
                    estado.contadorDetecciones = ...
                        estado.contadorDetecciones + length(ids);
                    lblContador.Text = num2str(estado.contadorDetecciones);

                    for i = 1:length(ids)
                        loc = locations(:,:,i);
                        imgMarcadores = insertShape(imgMarcadores, 'polygon', {loc}, ...
                            'Color', 'green', 'LineWidth', 3);
                        centro = mean(loc);
                        imgMarcadores = insertText(imgMarcadores, centro, ...
                            ['ID:' num2str(ids(i))], 'FontSize', 16, ...
                            'BoxOpacity', 0.6, 'TextColor', 'yellow');

                        if estado.conectado
                            if ids(i) == 0
                                write(estado.P, "0", "char");
                                escribirLog('  → Enviado: 0 (contenedor A)');
                                escribirSerial('0', 'TX');
                                lblUltimoID.Text = '0 → A';
                                lblUltimoID.FontColor = [0.4 0.85 0.55];
                            elseif ids(i) == 1
                                write(estado.P, "1", "char");
                                escribirLog('  → Enviado: 1 (contenedor B)');
                                escribirSerial('1', 'TX');
                                lblUltimoID.Text = '1 → B';
                                lblUltimoID.FontColor = [0.3 0.65 0.95];
                            elseif ids(i) == 2
                                write(estado.P, "2", "char");
                                escribirLog('  → Enviado: 2 (contenedor C)');
                                escribirSerial('2', 'TX');
                                lblUltimoID.Text = '2 → C';
                                lblUltimoID.FontColor = [0.95 0.75 0.3];
                            else
                                write(estado.P, "X", "char");
                                escribirLog(['  → ID ' num2str(ids(i)) ...
                                             ' no válido. Enviado: X']);
                                escribirSerial('X', 'TX');
                                lblUltimoID.Text = [num2str(ids(i)) ' → X'];
                                lblUltimoID.FontColor = [0.85 0.35 0.35];
                            end
                        else
                            escribirLog(['  (Puerto no conectado) ID: ' ...
                                         num2str(ids(i))]);
                            lblUltimoID.Text = [num2str(ids(i)) ' (sin envío)'];
                        end
                    end
                else
                    escribirLog('No se detectaron marcadores ArUco.');
                    imgMarcadores = insertText(imgRecColor, [5 5], 'Sin marcadores',...
                        'FontSize', 14, 'TextColor', 'red', 'BoxOpacity', 0.5);
                    if estado.conectado
                        write(estado.P, "X", "char");
                        escribirLog('  → Enviado: X (sin marcador)');
                        escribirSerial('X', 'TX');
                        lblUltimoID.Text = 'X';
                        lblUltimoID.FontColor = [0.85 0.35 0.35];
                    end
                end
            catch ME_aruco
                escribirLog(['Error ArUco: ' ME_aruco.message]);
            end

            estado.imgMarcadores = imgMarcadores;
            mostrarImagen(axImg(3), imgMarcadores);
            dibujarHistograma(axHist(3), imgMarcadores, coloresHist{3});
            drawnow;

            %--- 4. KIRSCH ---
            escribirLog('Calculando bordes Kirsch...');
            borde       = edge_kirsch(imgRec);
            borde_suave = imgaussfilt(borde, 1.2);
            bw          = threshold_custom(borde_suave, 120);
            estado.bwKirsch = bw;

            mostrarImagen(axImg(4), bw);
            dibujarHistograma(axHist(4), bw, coloresHist{4});
            drawnow;
            escribirLog('✓ Procesamiento completo.');

        catch ME
            escribirLog(['ERROR: ' ME.message]);
            uialert(fig, ME.message, 'Error de Procesamiento', 'Icon', 'error');
        end

        btnCapturar.Enable = 'on';
        btnCapturar.Text = '▶  Capturar y Analizar';
        btnCapturar.BackgroundColor = [0.55 0.85 0.65];
    end

    function guardarImagen(idx)
        switch idx
            case 1, img = estado.frame1;
            case 2, img = estado.imgRecortada;
            case 3, img = estado.imgMarcadores;
            case 4, img = estado.bwKirsch;
        end
        if isempty(img)
            uialert(fig, 'No hay imagen en este panel todavía.', ...
                    'Sin imagen', 'Icon', 'warning');
            return;
        end
        nombres = {'frame_original','recorte_grises','deteccion_aruco','kirsch_bw'};
        ts = datestr(now, 'yyyymmdd_HHMMSS');
        nombreDefecto = [nombres{idx} '_' ts '.png'];
        [archivo, ruta] = uiputfile( ...
            {'*.png','PNG';'*.jpg','JPEG';'*.bmp','BMP'}, ...
            'Guardar imagen como...', nombreDefecto);
        if isequal(archivo, 0), return; end
        try
            imwrite(img, fullfile(ruta, archivo));
            escribirLog(['💾 Guardado: ' archivo]);
        catch ME
            escribirLog(['ERROR al guardar: ' ME.message]);
            uialert(fig, ME.message, 'Error al guardar', 'Icon', 'error');
        end
    end

    function limpiarVista()
        for i = 1:4
            cla(axImg(i));
            axImg(i).XColor = 'none'; axImg(i).YColor = 'none';
            text(axImg(i), 0.5, 0.5, 'Sin imagen', ...
                'Color', [0.35 0.4 0.45], 'FontSize', 10, ...
                'HorizontalAlignment', 'center', 'Units', 'normalized');
            axImg(i).XLim = [0 1]; axImg(i).YLim = [0 1];

            cla(axHist(i));
            text(axHist(i), 0.5, 0.5, 'Sin datos', ...
                'Color', [0.3 0.35 0.4], 'FontSize', 8, ...
                'HorizontalAlignment', 'center', 'Units', 'normalized');
        end
        txtLog.Value = {'> Vista limpiada.'};
        escribirLog('Sistema listo.');
        lblUltimoID.Text = '—';
    end

    function cerrarApp()
        resp = uiconfirm(fig, 'Cerrar la aplicación?', 'Confirmar salida', ...
            'Options', {'Sí, cerrar','Cancelar'}, 'DefaultOption', 2, ...
            'Icon', 'question');
        if strcmp(resp, 'Sí, cerrar')
            try
                if estado.camaraActiva && ~isempty(estado.cam)
                    clear estado.cam;
                end
                if estado.conectado && ~isempty(estado.P)
                    clear estado.P;
                end
            catch
            end
            escribirLog('Cerrando aplicación...');
            try, stop(tSerial); delete(tSerial); catch, end
            pause(0.3);
            delete(fig);
        end
    end

